# Required since v4.11.0: Anthropic subscription OAuth token.
# This is the sole cloud LLM backend. Get it from your Claude Code session
# or claude.ai subscription settings. Subscription billing — cheaper than
# per-token API keys, which is why this replaces the legacy keys below.
CLAUDE_CODE_OAUTH_TOKEN=

# Optional: password for non-localhost web UI access
OUROBOROS_NETWORK_PASSWORD=

# Optional: notional spend cap in USD (subscription billing reports as 0;
# this caps the SDK's `total_cost_usd` observability signal)
TOTAL_BUDGET=50

# Optional: proxy for outbound HTTPS (LLM APIs, arxiv)
# Use VALOBOROS_PROXY instead of HTTP_PROXY/HTTPS_PROXY to avoid
# collision with host env vars. 127.0.0.1 is auto-fixed to the
# container gateway IP at startup.
# VALOBOROS_PROXY=http://127.0.0.1:10809

# ── Legacy per-token API keys (disabled by default) ─────────────────
# Per-token billing is materially more expensive than the subscription.
# Leave these commented out unless you have a specific reason to bypass
# OAuth. When CLAUDE_CODE_OAUTH_TOKEN is set, ouroboros/tools/shell.py
# unsets ANTHROPIC_API_KEY for child SDK processes so they bill against
# subscription rather than the metered key.
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
