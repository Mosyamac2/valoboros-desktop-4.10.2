# Required: LLM API key (OpenRouter routes to Claude, GPT, Gemini, etc.)
OPENROUTER_API_KEY=

# Optional: password for non-localhost web UI access
OUROBOROS_NETWORK_PASSWORD=

# Optional: other LLM providers
OPENAI_API_KEY=

# Recommended: enables Claude Code CLI for powerful multi-file evolution
ANTHROPIC_API_KEY=

# Optional: API spend limit in USD
TOTAL_BUDGET=50

# Optional: proxy for outbound HTTPS (LLM APIs, arxiv)
# Use VALOBOROS_PROXY instead of HTTP_PROXY/HTTPS_PROXY to avoid
# collision with host env vars. 127.0.0.1 is auto-fixed to the
# container gateway IP at startup.
# VALOBOROS_PROXY=http://127.0.0.1:10809
